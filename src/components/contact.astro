---
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Textarea } from "@/components/ui/textarea";
---

<section
  aria-labelledby="contact-heading"
  class="grid items-center gap-10 text-center md:text-center"
>
  <div class="max-w-2xl mx-auto">
    <h1
      id="contact-heading"
      class="text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight"
    >
      Contact Me
    </h1>
    <p class="mt-2 text-muted-foreground text-base sm:text-lg">
      Have a question or want to work together? Feel free to reach out!
    </p>
  </div>
</section>

<!-- Contact Form -->
<section class="mt-10 max-w-xl mx-auto w-full">
  <form
    id="component-contact-form"
    action="https://formspree.io/f/xldbzkve"
    method="POST"
    aria-label="Contact Form"
    class="space-y-6"
  >
    <div class="space-y-2">
      <label for="name" class="block text-sm font-medium"> Name </label>
      <Input
        type="text"
        id="name"
        name="name"
        placeholder="Your Name"
        required
        aria-required="true"
        className="w-full"
      />
    </div>

    <div class="space-y-2">
      <label for="email" class="block text-sm font-medium"> Email </label>
      <Input
        type="email"
        id="email"
        name="email"
        placeholder="you@example.com"
        required
        aria-required="true"
        className="w-full"
      />
    </div>

    <div class="space-y-2">
      <label for="message" class="block text-sm font-medium"> Message </label>
      <Textarea
        id="message"
        name="message"
        placeholder="Your message here..."
        required
        aria-required="true"
        className="w-full"
      />
    </div>

    <Button type="submit" size="lg" variant="default" className="w-full relative overflow-hidden" id="component-submit-btn">
      <span id="component-btn-text">Send Message</span>
      <svg id="component-btn-spinner" class="hidden animate-spin ml-2 h-5 w-5 text-white absolute right-4 top-1/2 -translate-y-1/2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
    </Button>
    
    <div id="component-form-message" class="hidden mt-4 p-4 rounded-lg text-center font-medium opacity-0"></div>
  </form>
</section>

<script>
  import { gsap } from "gsap";

  document.addEventListener("astro:page-load", () => {
    // Form Submission Handling
    const form = document.getElementById("component-contact-form") as HTMLFormElement;
    const messageEl = document.getElementById("component-form-message");
    const submitBtn = document.getElementById("component-submit-btn");
    const btnText = document.getElementById("component-btn-text");
    const btnSpinner = document.getElementById("component-btn-spinner");

    if (form && messageEl && submitBtn && btnText && btnSpinner) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        
        // Loading state
        submitBtn.setAttribute("disabled", "true");
        submitBtn.classList.add("opacity-80", "cursor-not-allowed");
        btnText.textContent = "Sending...";
        btnSpinner.classList.remove("hidden");
        messageEl.classList.add("hidden");
        
        const formData = new FormData(form);
        
        try {
          const response = await fetch(form.action, {
            method: "POST",
            body: formData,
            headers: {
              'Accept': 'application/json'
            }
          });
          
          messageEl.classList.remove("hidden");
          
          if (response.ok) {
            messageEl.innerHTML = `
              <div class="flex items-center justify-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span>Message sent successfully! I'll get back to you soon.</span>
              </div>
            `;
            messageEl.className = "mt-4 p-4 rounded-lg text-sm sm:text-base font-medium bg-green-500/10 text-green-600 dark:text-green-400 border border-green-500/20";
            form.reset();
            
            // Success animation
            gsap.fromTo(messageEl, 
              { opacity: 0, y: 15, scale: 0.95 }, 
              { opacity: 1, y: 0, scale: 1, duration: 0.5, ease: "back.out(1.5)" }
            );
          } else {
            throw new Error("Submission failed");
          }
        } catch (error) {
           messageEl.classList.remove("hidden");
           messageEl.innerHTML = `
              <div class="flex items-center justify-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <span>Oops! There was a problem submitting your form.</span>
              </div>
           `;
           messageEl.className = "mt-4 p-4 rounded-lg text-sm sm:text-base font-medium bg-red-500/10 text-red-600 dark:text-red-400 border border-red-500/20";
           
           // Error animation
           gsap.fromTo(messageEl, 
            { opacity: 0, x: -10 }, 
            { opacity: 1, x: 0, duration: 0.4, ease: "power2.out" }
          );
           gsap.to(messageEl, { x: 5, duration: 0.1, yoyo: true, repeat: 3, delay: 0.1 });
        } finally {
          // Restore button state
          submitBtn.removeAttribute("disabled");
          submitBtn.classList.remove("opacity-80", "cursor-not-allowed");
          btnText.textContent = "Send Message";
          btnSpinner.classList.add("hidden");
        }
      });
    }
  });
</script>
