<style>
  .marquee-container {
    width: 100%;
    display: flex;
    flex-wrap: nowrap;
    overflow: hidden;
  }
  
  .marquee-content {
    display: flex;
    flex-shrink: 0;
    min-width: 100%;
    animation: marquee 25s linear infinite;
  }

  @keyframes marquee {
    0% {
      transform: translateX(0%);
    }
    100% {
      transform: translateX(-100%);
    }
  }

  /* Optional: Pause animation on hover */
  .marquee-container:hover .marquee-content {
    animation-play-state: paused;
  }
</style>
