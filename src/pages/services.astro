---
import Layout from "../layouts/Layout.astro";
---

<Layout title="DevSumangal - Our Services">
  <section
    class="py-16 px-4 sm:px-6 lg:px-8 max-w-6xl mx-auto flex flex-col gap-12"
  >
    <h1
      class="gsap-service-header text-4xl sm:text-5xl font-bold text-center text-zinc-900 dark:text-white opacity-0 -translate-y-8"
    >
      Our Services
    </h1>

    <div class="grid gap-8 sm:grid-cols-2">
      <div
        class="gsap-service-card p-6 bg-white dark:bg-zinc-900 shadow-lg rounded-2xl border border-zinc-100 dark:border-zinc-800 hover:scale-[1.02] transition-transform duration-300 opacity-0 translate-y-12"
      >
        <h2
          class="text-2xl font-semibold text-indigo-600 dark:text-indigo-400 mb-2"
        >
          Web Development
        </h2>
        <p class="text-zinc-600 dark:text-zinc-300">
          Modern, responsive websites using Astro, React, and Tailwind CSS.
        </p>
      </div>

      <div
        class="gsap-service-card p-6 bg-white dark:bg-zinc-900 shadow-lg rounded-2xl border border-zinc-100 dark:border-zinc-800 hover:scale-[1.02] transition-transform duration-300 opacity-0 translate-y-12"
      >
        <h2
          class="text-2xl font-semibold text-indigo-600 dark:text-indigo-400 mb-2"
        >
          UI/UX Design
        </h2>
        <p class="text-zinc-600 dark:text-zinc-300">
          User-focused interfaces that are beautiful and intuitive.
        </p>
      </div>

      <div
        class="gsap-service-card p-6 bg-white dark:bg-zinc-900 shadow-lg rounded-2xl border border-zinc-100 dark:border-zinc-800 hover:scale-[1.02] transition-transform duration-300 opacity-0 translate-y-12"
      >
        <h2
          class="text-2xl font-semibold text-indigo-600 dark:text-indigo-400 mb-2"
        >
          SEO Optimization
        </h2>
        <p class="text-zinc-600 dark:text-zinc-300">
          Boost your visibility and rankings on search engines.
        </p>
      </div>

      <div
        class="gsap-service-card p-6 bg-white dark:bg-zinc-900 shadow-lg rounded-2xl border border-zinc-100 dark:border-zinc-800 hover:scale-[1.02] transition-transform duration-300 opacity-0 translate-y-12"
      >
        <h2
          class="text-2xl font-semibold text-indigo-600 dark:text-indigo-400 mb-2"
        >
          Maintenance & Support
        </h2>
        <p class="text-zinc-600 dark:text-zinc-300">
          Ongoing support to keep your site fast, secure, and updated.
        </p>
      </div>
    </div>
  </section>

  <script>
    import { gsap } from "gsap";

    document.addEventListener("astro:page-load", () => {
      if (!document.querySelector(".gsap-service-header")) return;

      // Header Animation
      gsap.to(".gsap-service-header", {
        y: 0,
        opacity: 1,
        duration: 0.8,
        ease: "power3.out",
      });

      // Cards Stagger Animation
      gsap.to(".gsap-service-card", {
        y: 0,
        opacity: 1,
        duration: 0.8,
        stagger: 0.15,
        ease: "back.out(1.2)",
        delay: 0.2,
      });
    });
  </script>
</Layout>
